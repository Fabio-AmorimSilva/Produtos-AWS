@model ProdutosAws.Domain.Entities.Product

@{
    ViewBag.Title = "Download Image";
    Layout = "_Layout";
}

<h2 class="d-flex justify-content-center">Download Image</h2>

<div class="d-flex justify-content-center mt-4">
    <div class="card" style="min-width: 480px;">
        <div class="card-header">
            <h5 class="mb-0">@Model.Name</h5>
            <small class="text-muted">@Model.Category</small>
        </div>
        <div class="card-body">
            @if (!Model.Images.Any())
            {
                <p class="text-center text-muted">No images available for this product.</p>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var image in Model.Images)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span class="text-truncate me-3">@image.Path</span>
                            <a class="btn btn-primary btn-sm flex-shrink-0"
                               asp-action="DownloadImage"
                               asp-route-productId="@Model.Id"
                               asp-route-path="@image.Path">
                                Download
                            </a>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="card-footer">
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </div>
    </div>
</div>
